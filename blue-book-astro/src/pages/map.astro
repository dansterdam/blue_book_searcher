---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Sighting Map"
  description="Map of UFO sightings from the Flying Saucer Files database — 10,807 cases plotted by location."
>
  <div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1 h-6 bg-dossier-amber"></div>
        <h1 class="font-typewriter text-2xl text-dossier-amber-bright uppercase tracking-widest">
          Sighting Map
        </h1>
      </div>
      <p class="font-mono text-xs text-dossier-muted ml-4">
        Click any marker to view the case · Clusters expand on zoom
      </p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-4 font-mono text-xs">
      <label class="flex items-center gap-2 text-dossier-muted cursor-pointer">
        <input type="checkbox" id="filter-photos" class="accent-dossier-amber" />
        <span>📷 Photographic evidence only</span>
      </label>
      <label class="flex items-center gap-2 text-dossier-muted cursor-pointer">
        <span>Year:</span>
        <input id="filter-year-min" type="number" min="1947" max="1969" placeholder="1947"
          class="w-16 bg-dossier-surface border border-dossier-border text-dossier-text px-2 py-0.5 rounded" />
        <span>–</span>
        <input id="filter-year-max" type="number" min="1947" max="1969" placeholder="1969"
          class="w-16 bg-dossier-surface border border-dossier-border text-dossier-text px-2 py-0.5 rounded" />
      </label>
      <button id="filter-apply"
        class="border border-dossier-amber/50 text-dossier-amber px-3 py-0.5 rounded hover:bg-dossier-amber/10 transition-colors uppercase tracking-wider">
        Apply
      </button>
      <button id="filter-reset"
        class="border border-dossier-border text-dossier-muted px-3 py-0.5 rounded hover:border-dossier-amber hover:text-dossier-amber transition-colors uppercase tracking-wider">
        Reset
      </button>
      <span id="case-count" class="ml-auto text-dossier-muted self-center"></span>
    </div>

    <!-- Map container -->
    <div id="map-loading" class="border border-dossier-border rounded bg-dossier-surface flex items-center justify-center h-[600px]">
      <div class="text-center">
        <div class="font-typewriter text-dossier-amber text-xl animate-pulse mb-2">LOADING MAP DATA</div>
        <div class="font-mono text-dossier-muted text-xs">Plotting case locations...</div>
      </div>
    </div>
    <div id="map" class="hidden border border-dossier-border rounded overflow-hidden" style="height: 600px;"></div>

    <!-- No geocode data notice -->
    <div id="no-data" class="hidden border border-dossier-border rounded bg-dossier-surface p-12 text-center">
      <div class="font-typewriter text-dossier-amber text-xl mb-3">Map Data Not Yet Generated</div>
      <p class="font-mono text-dossier-muted text-sm max-w-md mx-auto">
        Run <code class="text-dossier-amber">python3 scripts/geocode-locations.py</code> from the
        <code class="text-dossier-amber">blue-book-astro/</code> directory, then rebuild.
        This is a one-time ~97 minute process.
      </p>
    </div>

  </div>
</BaseLayout>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<!-- Leaflet MarkerCluster CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.Default.css" />

<style>
  /* Override Leaflet's default blue tiles with a dark/amber theme */
  .leaflet-container {
    background: #0d0d0d;
    font-family: 'Source Code Pro', monospace;
  }
  .leaflet-popup-content-wrapper {
    background: #1a1a1a;
    border: 1px solid #3a3a2a;
    border-radius: 4px;
    color: #c8b97a;
    font-family: 'Source Code Pro', monospace;
    font-size: 12px;
  }
  .leaflet-popup-tip {
    background: #1a1a1a;
  }
  .leaflet-popup-close-button {
    color: #888 !important;
  }
  .marker-cluster-small,
  .marker-cluster-medium,
  .marker-cluster-large {
    background-color: rgba(194, 154, 50, 0.3);
  }
  .marker-cluster-small div,
  .marker-cluster-medium div,
  .marker-cluster-large div {
    background-color: rgba(194, 154, 50, 0.7);
    color: #0d0d0d;
    font-weight: bold;
    font-family: 'Source Code Pro', monospace;
    font-size: 11px;
  }
</style>

<script>
async function initMap() {
  // Fetch map data
  let cases: any[] = [];
  try {
    const res = await fetch('/data/map-index.json');
    if (!res.ok) throw new Error('not found');
    cases = await res.json();
  } catch {
    document.getElementById('map-loading')!.classList.add('hidden');
    document.getElementById('no-data')!.classList.remove('hidden');
    return;
  }

  if (!cases.length) {
    document.getElementById('map-loading')!.classList.add('hidden');
    document.getElementById('no-data')!.classList.remove('hidden');
    return;
  }

  // Load Leaflet + MarkerCluster dynamically
  await loadScript('https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js');
  await loadScript('https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/leaflet.markercluster.min.js');

  const L = (window as any).L;

  document.getElementById('map-loading')!.classList.add('hidden');
  document.getElementById('map')!.classList.remove('hidden');

  // Initialise map centred on continental US
  const map = L.map('map', { preferCanvas: true }).setView([38.5, -96], 4);

  // Dark OpenStreetMap tiles via Stadia (free, no API key for low usage)
  L.tileLayer('https://tiles.stadiamaps.com/tiles/alidade_smooth_dark/{z}/{x}/{y}{r}.png', {
    maxZoom: 18,
    attribution: '© <a href="https://stadiamaps.com/">Stadia Maps</a>, © <a href="https://openmaptiles.org/">OpenMapTiles</a>, © <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
  }).addTo(map);

  // Custom amber marker icon
  const amberIcon = L.divIcon({
    className: '',
    html: '<div style="width:8px;height:8px;background:#c29a32;border-radius:50%;border:1px solid #e8c840;opacity:0.85;"></div>',
    iconSize: [8, 8],
    iconAnchor: [4, 4],
  });

  // Build cluster group
  let clusterGroup = buildClusterGroup(L, cases, amberIcon);
  map.addLayer(clusterGroup);
  updateCount(cases.length);

  // Filters
  document.getElementById('filter-apply')!.addEventListener('click', () => {
    const photosOnly = (document.getElementById('filter-photos') as HTMLInputElement).checked;
    const yearMin    = parseInt((document.getElementById('filter-year-min') as HTMLInputElement).value) || 1947;
    const yearMax    = parseInt((document.getElementById('filter-year-max') as HTMLInputElement).value) || 1969;

    const filtered = cases.filter(c => {
      if (photosOnly && !c.contains_photographs) return false;
      if (c.year && (c.year < yearMin || c.year > yearMax)) return false;
      return true;
    });

    map.removeLayer(clusterGroup);
    clusterGroup = buildClusterGroup(L, filtered, amberIcon);
    map.addLayer(clusterGroup);
    updateCount(filtered.length);
  });

  document.getElementById('filter-reset')!.addEventListener('click', () => {
    (document.getElementById('filter-photos') as HTMLInputElement).checked = false;
    (document.getElementById('filter-year-min') as HTMLInputElement).value = '';
    (document.getElementById('filter-year-max') as HTMLInputElement).value = '';

    map.removeLayer(clusterGroup);
    clusterGroup = buildClusterGroup(L, cases, amberIcon);
    map.addLayer(clusterGroup);
    updateCount(cases.length);
  });
}

function buildClusterGroup(L: any, cases: any[], icon: any) {
  const group = L.markerClusterGroup({
    maxClusterRadius: 40,
    spiderfyOnMaxZoom: true,
    showCoverageOnHover: false,
    zoomToBoundsOnClick: true,
  });

  for (const c of cases) {
    const marker = L.marker([c.lat, c.lng], { icon });
    const photoTag = c.contains_photographs ? '<span style="color:#6dbf6d">📷 PHOTO</span> · ' : '';
    const witnesses = c.witnesses != null ? `${c.witnesses} witness${c.witnesses !== 1 ? 'es' : ''}` : 'witnesses unknown';
    marker.bindPopup(`
      <div style="min-width:200px;max-width:260px">
        <div style="color:#888;margin-bottom:4px;font-size:10px">${photoTag}${c.date} · ${witnesses}</div>
        <div style="color:#e8c840;font-weight:bold;margin-bottom:6px;font-size:11px">${c.location}</div>
        <div style="color:#aaa;margin-bottom:8px;font-size:11px;line-height:1.4">${c.summary || ''}</div>
        <a href="/case?id=${c.id}" style="color:#c29a32;text-decoration:none;font-size:10px;border:1px solid #c29a32;padding:2px 8px;border-radius:2px;display:inline-block">
          View case file →
        </a>
      </div>
    `, { maxWidth: 280 });
    group.addLayer(marker);
  }

  return group;
}

function updateCount(n: number) {
  const el = document.getElementById('case-count');
  if (el) el.textContent = `${n.toLocaleString()} cases plotted`;
}

function loadScript(src: string): Promise<void> {
  return new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = src;
    s.onload = () => resolve();
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

initMap();
</script>
