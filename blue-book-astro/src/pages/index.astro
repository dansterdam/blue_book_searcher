---
import BaseLayout from '../layouts/BaseLayout.astro';
import stats from '../data/stats.json';
import casesIndex from '../data/cases-index.json';

// Get a selection of interesting recent cases for the homepage
const featuredCases = casesIndex
  .filter(c => c.summary && c.has_json && c.witnesses && c.witnesses > 1)
  .sort(() => 0.5 - Math.random())
  .slice(0, 6);

// Peak year
const peakYear = stats.casesByYear.reduce((max, y) => y.count > max.count ? y : max, stats.casesByYear[0]);
---
<BaseLayout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden pt-16 pb-14">
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-12 items-start">

        <!-- Left: text -->
        <div>
          <!-- Label line like the Blue Book cover -->
          <p class="font-mono text-xs text-dossier-muted tracking-[0.3em] uppercase mb-4">Project Blue Book · 1947–1969</p>

          <!-- Big editorial heading -->
          <h1 class="font-display text-[clamp(3rem,9vw,7rem)] text-dossier-text-bright leading-[0.9] tracking-tight mb-8">
            The Flying<br/>Saucer Files
          </h1>

          <div class="w-full h-px bg-dossier-border mb-8"></div>

          <!-- Description -->
          <p class="font-sans text-dossier-text text-lg leading-relaxed mb-6 max-w-lg">
            A searchable archive of {stats.total.toLocaleString()} UFO case files
            spanning {stats.yearRange.min}–{stats.yearRange.max}. Full transcripts,
            witness accounts, and original source documents.
          </p>

          <!-- Stats -->
          <div class="font-mono text-sm text-dossier-muted space-y-1 mb-10">
            <div><span class="text-dossier-text-bright font-bold">{stats.total.toLocaleString()}</span> case files</div>
            <div><span class="text-dossier-text-bright font-bold">{stats.yearRange.min}–{stats.yearRange.max}</span> years covered</div>
            <div><span class="text-dossier-text-bright font-bold">{stats.withPhotos}</span> with photographs</div>
          </div>

          <!-- Search bar -->
          <div class="max-w-xl">
            <form action="/search" method="get" class="flex gap-2">
              <input
                type="text"
                name="q"
                placeholder="Search cases, locations, objects..."
                class="flex-1 bg-dossier-bg/60 backdrop-blur-sm border border-dossier-border text-dossier-text-bright font-mono text-sm px-4 py-3 rounded-none focus:outline-none focus:border-dossier-text-bright placeholder-dossier-muted"
                aria-label="Search the Flying Saucer Files"
              />
              <button
                type="submit"
                class="bg-dossier-text-bright hover:bg-dossier-text text-dossier-bg font-display font-bold text-sm px-6 py-3 rounded-none transition-colors uppercase tracking-wider"
              >
                Search
              </button>
            </form>
            <p class="text-xs font-mono text-dossier-muted mt-2">
              Or <a href="/search" class="text-dossier-text underline underline-offset-2">use advanced filters</a> — date range, witnesses, location, object type
            </p>
          </div>
        </div>

        <!-- Right: actual Blue Book field photos (Toms River, NJ, 1945) -->
        <div class="hidden lg:block relative h-[520px] select-none pointer-events-none">
          <!-- Photo A: slightly tilted left, behind -->
          <div class="absolute top-0 right-4 w-[340px] shadow-lg"
               style="transform: rotate(-2.5deg); transform-origin: top center;">
            <img
              src="/doc-photo-a.webp"
              alt="Project Blue Book field photographs, Toms River NJ 1945"
              class="w-full grayscale opacity-90 border border-black/20"
              loading="eager"
              decoding="async"
            />
          </div>
          <!-- Photo B: slightly tilted right, overlapping in front -->
          <div class="absolute top-36 left-0 w-[300px] shadow-xl"
               style="transform: rotate(3deg); transform-origin: top left;">
            <img
              src="/doc-photo-b.webp"
              alt="Project Blue Book field photographs showing object formation, 120° and 180°"
              class="w-full grayscale opacity-90 border border-black/20"
              loading="eager"
              decoding="async"
            />
          </div>
          <!-- Caption -->
          <p class="absolute bottom-0 right-0 font-mono text-[9px] text-dossier-muted tracking-widest uppercase opacity-60">
            Toms River, NJ · Nov 1945 · Case #7276022
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dossier-border bg-dossier-surface/60 backdrop-blur-sm py-6">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="p-4">
          <div class="font-typewriter text-3xl text-dossier-amber-bright glow-amber">{stats.total.toLocaleString()}</div>
          <div class="font-mono text-xs text-dossier-muted uppercase tracking-widest mt-1">Total Cases</div>
        </div>
        <div class="p-4">
          <div class="font-typewriter text-3xl text-dossier-amber-bright">{stats.yearRange.min}–{stats.yearRange.max}</div>
          <div class="font-mono text-xs text-dossier-muted uppercase tracking-widest mt-1">Years Covered</div>
        </div>
        <div class="p-4">
          <div class="font-typewriter text-3xl text-dossier-amber-bright">{peakYear.year}</div>
          <div class="font-mono text-xs text-dossier-muted uppercase tracking-widest mt-1">Peak Year ({peakYear.count} cases)</div>
        </div>
        <div class="p-4">
          <div class="font-typewriter text-3xl text-dossier-amber-bright">{stats.withPhotos}</div>
          <div class="font-mono text-xs text-dossier-muted uppercase tracking-widest mt-1">Photographic Evidence</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Year activity bar chart (ASCII-style) -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="font-typewriter text-xl text-dossier-amber mb-2 uppercase tracking-widest">
      ▶ Incident Frequency by Year
    </h2>
    <p class="font-mono text-xs text-dossier-muted mb-6">Click a year to browse all cases from that period</p>

    <div class="bg-dossier-surface/60 border border-dossier-border rounded p-4 overflow-x-auto">
      {(() => {
        const maxCount = Math.max(...stats.casesByYear.map(x => x.count));
        const BAR_MAX_PX = 96;
        return (
          <div class="flex items-end gap-1 min-w-[600px]" style="height: 128px;">
            {stats.casesByYear.map((y) => {
              const barPx = Math.max(2, Math.round((y.count / maxCount) * BAR_MAX_PX));
              return (
                <a
                  href={`/browse?year=${y.year}`}
                  class="flex-1 flex flex-col items-center justify-end gap-1 group cursor-pointer h-full"
                  title={`${y.year}: ${y.count} cases`}
                >
                  <div class="relative w-full flex-shrink-0" style={`height: ${barPx}px`}>
                    <div class="w-full h-full bg-dossier-amber/70 group-hover:bg-dossier-amber transition-colors rounded-t"></div>
                    <div class="absolute -top-5 left-1/2 -translate-x-1/2 text-[9px] font-mono text-dossier-amber-bright opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
                      {y.count}
                    </div>
                  </div>
                  <span class="text-[8px] font-mono text-dossier-muted group-hover:text-dossier-amber transition-colors flex-shrink-0" style="writing-mode: vertical-rl; transform: rotate(180deg); white-space: nowrap;">
                    {y.year}
                  </span>
                </a>
              );
            })}
          </div>
        );
      })()}
    </div>
  </section>

  <!-- Featured Cases -->
  <section class="max-w-5xl mx-auto px-4 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-typewriter text-xl text-dossier-amber uppercase tracking-widest">
        ▶ Sample Case Files
      </h2>
      <a href="/search" class="font-mono text-xs text-dossier-muted hover:text-dossier-amber transition-colors uppercase tracking-wider">
        View all →
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {featuredCases.map((c) => (
        <a
          href={`/case?id=${c.id}`}
          class="block bg-dossier-surface/70 border border-dossier-border rounded hover:border-dossier-amber transition-all group p-4 relative overflow-hidden"
        >
          <!-- Corner decoration -->
          <div class="absolute top-0 right-0 w-6 h-6 border-l border-b border-dossier-amber/30 group-hover:border-dossier-amber/60 transition-colors"></div>

          <!-- Date badge -->
          <div class="flex items-center gap-2 mb-3">
            <span class="font-mono text-xs bg-dossier-amber/10 text-dossier-amber border border-dossier-amber/30 px-2 py-0.5 rounded">
              {c.date}
            </span>
            {c.contains_photographs && (
              <span class="font-mono text-xs bg-dossier-green/10 text-dossier-green-bright border border-dossier-green/30 px-2 py-0.5 rounded">
                📷 PHOTO
              </span>
            )}
          </div>

          <!-- Location -->
          <p class="font-mono text-dossier-muted text-xs uppercase tracking-wider mb-2 truncate">
            📍 {c.location}
          </p>

          <!-- Summary -->
          <p class="font-mono text-dossier-text text-xs leading-relaxed line-clamp-3 mb-3">
            {c.summary || 'No summary available.'}
          </p>

          <!-- Metadata row -->
          <div class="flex items-center gap-3 text-xs font-mono text-dossier-muted border-t border-dossier-border pt-3 mt-auto">
            {c.witnesses !== null && c.witnesses !== undefined && (
              <span title="Witnesses">👁 {c.witnesses}</span>
            )}
            {c.sighted_object && (
              <span class="truncate" title={c.sighted_object}>⊙ {c.sighted_object.slice(0, 30)}{c.sighted_object.length > 30 ? '...' : ''}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Top states -->
  <section class="max-w-5xl mx-auto px-4 pb-12">
    <h2 class="font-typewriter text-xl text-dossier-amber mb-6 uppercase tracking-widest">
      ▶ Incident Hotspots
    </h2>
    <div class="bg-dossier-surface/60 border border-dossier-border rounded p-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 gap-3">
        {stats.topStates.slice(0, 10).map((s) => (
          <a
            href={`/browse?state=${encodeURIComponent(s.state)}`}
            class="flex flex-col items-center p-3 border border-dossier-border rounded hover:border-dossier-amber transition-colors group text-center"
          >
            <span class="font-mono text-lg text-dossier-amber-bright group-hover:text-dossier-amber-bright">
              {s.count}
            </span>
            <span class="font-mono text-xs text-dossier-muted mt-1 group-hover:text-dossier-text transition-colors">{s.state}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick-access browsing -->
  <section class="max-w-5xl mx-auto px-4 pb-16">
    <h2 class="font-typewriter text-xl text-dossier-amber mb-6 uppercase tracking-widest">
      ▶ Browse the Archive
    </h2>
    <div class="grid sm:grid-cols-3 gap-4">
      <a href="/search?photos=Yes" class="bg-dossier-surface/60 border border-dossier-border rounded p-6 hover:border-dossier-amber transition-all group text-center">
        <div class="text-3xl mb-3">📷</div>
        <div class="font-typewriter text-dossier-amber group-hover:text-dossier-amber-bright text-lg mb-2">Photographic Evidence</div>
        <div class="font-mono text-dossier-muted text-xs">{stats.withPhotos} cases include photographs or physical evidence</div>
      </a>
      <a href="/search?witnesses=10%2B" class="bg-dossier-surface/60 border border-dossier-border rounded p-6 hover:border-dossier-amber transition-all group text-center">
        <div class="text-3xl mb-3">👥</div>
        <div class="font-typewriter text-dossier-amber group-hover:text-dossier-amber-bright text-lg mb-2">Mass Sightings</div>
        <div class="font-mono text-dossier-muted text-xs">Cases with 10+ confirmed witnesses</div>
      </a>
      <a href="/stats" class="bg-dossier-surface/60 border border-dossier-border rounded p-6 hover:border-dossier-amber transition-all group text-center">
        <div class="text-3xl mb-3">📊</div>
        <div class="font-typewriter text-dossier-amber group-hover:text-dossier-amber-bright text-lg mb-2">Statistical Analysis</div>
        <div class="font-mono text-dossier-muted text-xs">Patterns, distributions, and trends across the full archive</div>
      </a>
    </div>
  </section>
</BaseLayout>
