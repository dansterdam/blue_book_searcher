---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="File Not Found">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="inline-block border-2 border-dossier-red px-4 py-1 mb-6">
      <span class="font-mono text-dossier-red text-xs tracking-[0.4em] uppercase font-bold">ACCESS DENIED</span>
    </div>
    <h1 class="font-typewriter text-6xl text-dossier-amber mb-4">404</h1>
    <p class="font-typewriter text-xl text-dossier-amber-bright mb-3">Case File Not Found</p>
    <p class="font-mono text-dossier-muted text-sm mb-8">
      This record could not be located in the archive. It may have been redacted, mis-filed, or may not exist.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/search" class="font-mono text-sm border border-dossier-border text-dossier-muted px-4 py-2 rounded hover:border-dossier-amber hover:text-dossier-amber transition-colors">
        Search archive →
      </a>
      <a href="/" class="font-mono text-sm border border-dossier-border text-dossier-muted px-4 py-2 rounded hover:border-dossier-amber hover:text-dossier-amber transition-colors">
        Return to home →
      </a>
    </div>
  </div>
</BaseLayout>
