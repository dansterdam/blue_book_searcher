---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Project Blue Book Archive',
  description = 'Declassified USAF UFO investigation records, 1947–1969. Search and browse 10,807 Project Blue Book case files.',
  ogImage = '/og-image.png',
} = Astro.props;

const fullTitle = title === 'Project Blue Book Archive'
  ? title
  : `${title} — Project Blue Book Archive`;
---
<!DOCTYPE html>
<html lang="en" class="bg-dossier-bg text-dossier-text">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Source+Code+Pro:wght@300;400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Pagefind CSS (loaded only when search is active) -->
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" media="none" onload="this.media='all'" />
</head>
<body class="min-h-screen bg-dossier-bg text-dossier-text antialiased">

  <!-- Scanline overlay for CRT effect -->
  <div class="pointer-events-none fixed inset-0 z-50 overflow-hidden opacity-[0.03]" aria-hidden="true">
    <div class="h-full w-full bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,0.5)_2px,rgba(0,0,0,0.5)_4px)]"></div>
  </div>

  <!-- Top classification banner -->
  <div class="bg-dossier-red text-white text-center py-1 text-xs font-mono tracking-[0.3em] uppercase font-bold">
    ██ DECLASSIFIED — DEPARTMENT OF THE AIR FORCE — FOIA RELEASE ██
  </div>

  <!-- Navigation -->
  <nav class="border-b border-dossier-border bg-dossier-surface/80 backdrop-blur-sm sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-full border-2 border-dossier-amber flex items-center justify-center group-hover:border-dossier-amber-bright transition-colors">
            <svg viewBox="0 0 24 24" class="w-4 h-4 text-dossier-amber group-hover:text-dossier-amber-bright transition-colors" fill="currentColor">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1C6.477 1 2 5.477 2 11c0 3.026 1.35 5.74 3.488 7.601L12 23l6.512-4.399A9.965 9.965 0 0022 11C22 5.477 17.523 1 12 1zm0 16a6 6 0 110-12 6 6 0 010 12z" opacity="0.4"/>
            </svg>
          </div>
          <span class="font-typewriter text-dossier-amber-bright text-sm tracking-widest uppercase hidden sm:block">
            Project Blue Book
          </span>
        </a>

        <!-- Nav links -->
        <div class="flex items-center gap-1">
          <a href="/" class="px-3 py-2 text-xs font-mono text-dossier-muted hover:text-dossier-amber transition-colors uppercase tracking-wider">Home</a>
          <a href="/search" class="px-3 py-2 text-xs font-mono text-dossier-muted hover:text-dossier-amber transition-colors uppercase tracking-wider">Search</a>
          <a href="/browse" class="px-3 py-2 text-xs font-mono text-dossier-muted hover:text-dossier-amber transition-colors uppercase tracking-wider">Browse</a>
          <a href="/stats" class="px-3 py-2 text-xs font-mono text-dossier-muted hover:text-dossier-amber transition-colors uppercase tracking-wider">Stats</a>
          <a href="/about" class="px-3 py-2 text-xs font-mono text-dossier-muted hover:text-dossier-amber transition-colors uppercase tracking-wider hidden sm:block">About</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-dossier-border bg-dossier-surface mt-16 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="text-center sm:text-left">
          <p class="font-typewriter text-dossier-amber text-sm tracking-widest uppercase">Project Blue Book Archive</p>
          <p class="text-dossier-muted text-xs mt-1 font-mono">10,807 declassified USAF UFO investigation records · 1947–1969</p>
        </div>
        <div class="text-xs font-mono text-dossier-muted text-center sm:text-right">
          <p>Source: National Archives & Records Administration</p>
          <p>Original documents via Fold3 · Public Domain</p>
        </div>
      </div>
      <div class="mt-6 pt-4 border-t border-dossier-border text-center">
        <p class="text-xs font-mono text-dossier-muted opacity-60 tracking-widest">
          ░░ UNCLASSIFIED // FOR OFFICIAL USE ONLY ░░
        </p>
      </div>
    </div>
  </footer>

</body>
</html>
