---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'The Flying Saucer Files',
  description = 'A searchable database of 10,807 UFO case files spanning 1947–1969. Full transcripts, witness accounts, and original source documents.',
  ogImage = '/og-image.png',
} = Astro.props;

const fullTitle = title === 'The Flying Saucer Files'
  ? title
  : `${title} — The Flying Saucer Files`;

---
<!DOCTYPE html>
<html lang="en" class="bg-dossier-bg text-dossier-text">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Source+Code+Pro:wght@300;400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Pagefind CSS (loaded only when search is active) -->
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" media="none" onload="this.media='all'" />

  <ViewTransitions />
</head>
<body class="min-h-screen text-dossier-text antialiased">

  <!-- Navigation -->
  <nav class="border-b border-dossier-border bg-dossier-bg/70 backdrop-blur-md sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <!-- Logo -->
        <a href="/" class="group">
          <span class="font-display font-bold text-dossier-text-bright text-base tracking-tight hover:text-dossier-amber transition-colors">
            The Flying Saucer Files
          </span>
        </a>

        <!-- Nav links -->
        <div class="flex items-center gap-1">
          <a href="/" class="px-3 py-2 text-sm font-sans text-dossier-muted hover:text-dossier-text-bright transition-colors">Home</a>
          <a href="/search" class="px-3 py-2 text-sm font-sans text-dossier-muted hover:text-dossier-text-bright transition-colors">Search</a>
          <a href="/browse" class="px-3 py-2 text-sm font-sans text-dossier-muted hover:text-dossier-text-bright transition-colors">Browse</a>
          <a href="/map" class="px-3 py-2 text-sm font-sans text-dossier-muted hover:text-dossier-text-bright transition-colors">Map</a>
          <a href="/stats" class="px-3 py-2 text-sm font-sans text-dossier-muted hover:text-dossier-text-bright transition-colors hidden sm:block">Stats</a>
          <a href="/about" class="px-3 py-2 text-sm font-sans text-dossier-muted hover:text-dossier-text-bright transition-colors hidden sm:block">About</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-dossier-border bg-dossier-surface mt-16 py-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row items-start justify-between gap-6">
        <div>
          <p class="font-display font-bold text-dossier-text-bright text-lg">The Flying Saucer Files</p>
          <p class="text-dossier-muted text-xs mt-1 font-mono">10,807 UFO case files · 1947–1969</p>
        </div>
        <div class="text-xs font-mono text-dossier-muted text-left sm:text-right space-y-1">
          <p>Source: National Archives & Records Administration</p>
          <p>Original documents via Fold3 · Public Domain</p>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>
